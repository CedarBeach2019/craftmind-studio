# ─────────────────────────────────────────────
# CraftMind Studio — Environment Configuration
# ─────────────────────────────────────────────

# Required: API key for the LLM (Director AI)
ZAI_API_KEY=

# Required: ElevenLabs API key for voice synthesis
ELEVENLABS_API_KEY=

# Optional: Custom path to ffmpeg binary
# FFMPEG_PATH=/usr/local/bin/ffmpeg

# ── Minecraft Server ────────────────────────
MC_HOST=localhost
MC_PORT=25565
MC_VERSION=1.20.4

# ── Rendering ───────────────────────────────
RENDER_FPS=24
RENDER_WIDTH=1920
RENDER_HEIGHT=1080
RENDER_CODEC=libx264
RENDER_PRESET=medium
RENDER_CRF=18

# ── Audio ───────────────────────────────────
# TTS model ID (default: eleven_multilingual_v2)
TTS_MODEL_ID=eleven_multilingual_v2

# Default voice stability (0-1, default: 0.5)
VOICE_STABILITY=0.5
# Default similarity boost (0-1, default: 0.75)
VOICE_SIMILARITY=0.75
